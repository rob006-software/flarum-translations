{
    "flarum-mentions": {
        "admin": {
            "permissions": {
                "mention_groups_label": "提及组群"
            },
            "settings": {
                "allow_username_format_label": "允许@用户名",
                "allow_username_format_text": "Flarum 默认提及格式是「@外显昵称#ID」，默认外显昵称为用户名。\n启用 Nicknames 扩展程序后，你可能会将外显昵称更改为 nickname。开启此设置可允许用户同时使用旧格式「@用户名」，不过在保存时系统会自动转换成新格式。\n"
            }
        },
        "forum": {
            "composer": {
                "mention_tooltip": "提及用户、组或楼层",
                "reply_to_post_text": "回复 #{number}"
            },
            "mentioned_by": {
                "title": "所有回复",
                "load_more_button": "=> core.ref.load_more"
            },
            "notifications": {
                "others_text": "=> core.ref.some_others",
                "post_mentioned_text": "{username} 回复了您",
                "user_mentioned_text": "{username} 提及了您",
                "group_mentioned_text": "{username} 提到了您所属的组群"
            },
            "post": {
                "mentioned_by_more_text": "等 {count} 个回帖。",
                "mentioned_by_self_text": "{users} 回复了您的帖子",
                "mentioned_by_text": "{users} 回复了此帖",
                "others_text": "=> core.ref.some_others",
                "quote_button": "引用",
                "reply_link": "=> core.ref.reply",
                "you_text": "=> core.ref.you"
            },
            "settings": {
                "notify_post_mentioned_label": "有人回复了我",
                "notify_user_mentioned_label": "有人提到了我",
                "notify_group_mentioned_label": "有人在帖子中提到了我在的组群"
            },
            "user": {
                "mentions_link": "被提及"
            },
            "post_mention": {
                "deleted_text": "[未知用户]"
            },
            "group_mention": {
                "deleted_text": "[未知组群]"
            }
        },
        "email": {
            "post_mentioned": {
                "subject": "{replier_display_name} 回复了您【{title}】",
                "plain": {
                    "body": "{replier_display_name} 在 {title} 中回复了您的帖子 (#{post_number})。\n\n{url}\n\n---\n\n{content}\n"
                },
                "html": {
                    "body": "{replier_display_name} 在 [{title}]({url}) 中回复了您的帖子 (#{post_number})。"
                }
            },
            "user_mentioned": {
                "subject": "{mentioner_display_name} 提及了您【{title}】",
                "plain": {
                    "body": "{mentioner_display_name} 在 {title} 的回复中提及了您。\n\n{url}\n\n---\n\n{content}\n"
                },
                "html": {
                    "body": "{mentioner_display_name} 在 [{title}]({url}) 的回复中提及了您。"
                }
            },
            "group_mentioned": {
                "subject": "{mentioner_display_name} 在 {title} 中提到了您所属的组群",
                "plain": {
                    "body": "{mentioner_display_name} 在 {title} 中提及了您所属的用户组。\n\n{url}\n\n---\n\n{content}\n"
                },
                "html": {
                    "body": "{mentioner_display_name} 在 [{title}]({url}) 中提及了您所属的用户组。"
                }
            }
        },
        "lib": {
            "gambits": {
                "posts": {
                    "mentioned": {
                        "key": "mentioned",
                        "hint": "被提及用户的 ID 或用户名"
                    }
                }
            }
        }
    }
}
