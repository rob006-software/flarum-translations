{
    "flarum-sticky": {
        "admin": {
            "settings": {
                "enable_display_excerpt": "置顶话题未读时显示首帖摘要",
                "only_sticky_unread_discussions_label": "仅置顶未读话题",
                "only_sticky_unread_discussions_help": "在「全部话题」页面，未读置顶话题将固定在顶部，已读置顶话题则按常规顺序排序。"
            },
            "permissions": {
                "sticky_discussions_label": "置顶话题"
            }
        },
        "forum": {
            "badge": {
                "sticky_tooltip": "置顶"
            },
            "discussion_controls": {
                "sticky_button": "=> flarum-sticky.ref.sticky",
                "unsticky_button": "取消置顶"
            },
            "post_stream": {
                "discussion_stickied_text": "{username}于{time}置顶此帖。",
                "discussion_unstickied_text": "{username}于{time}取消置顶。"
            }
        },
        "lib": {
            "gambits": {
                "discussions": {
                    "sticky": {
                        "key": "sticky"
                    }
                }
            }
        },
        "ref": {
            "sticky": "置顶"
        }
    },
    "flarum-audit": {
        "lib": {
            "browser": {
                "discussion": {
                    "stickied": "固定话题{discussion}",
                    "unstickied": "取消固定话题{discussion}"
                }
            }
        }
    }
}
